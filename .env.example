# Copy this file to ".env" and fill in your Supabase project values.
# These are safe to expose in the browser (the anon key is public by design;
# your data is protected by Supabase Row Level Security).
#
# Leave them blank to run the app in LOCAL mode (data stored only on this
# device, no sign-in, no sync). Fill them in to enable cloud sync between
# both phones and the website.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public VAPID key for push notifications (safe to expose). Generate with:
#   npx web-push generate-vapid-keys
# The matching PRIVATE key goes in your Supabase Edge Function secrets, NOT here.
VITE_VAPID_PUBLIC_KEY=
